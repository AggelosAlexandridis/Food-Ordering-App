<AddressScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        BoxLayout:
            size_hint_y: None
            height: 50
            spacing: 10

            Button:
                text: "<"
                size_hint_x: None
                width: 50
                on_press: app.go_back_to_dashboard()

            Label:
                text: "Add New Address"
                font_size: 22
                bold: True

        Widget:
            size_hint_y: None
            height: dp(20)

        TextInput:
            id: address_input
            hint_text: "Enter your delivery street address..."
            multiline: False
            size_hint_y: None
            height: dp(50)
            font_size: 18
            padding: [10, 12, 10, 10]

        Label:
            id: error_label
            text: ""
            color: (0.9, 0.2, 0.2, 1)
            font_size: 16
            size_hint_y: None
            height: self.texture_size[1] if self.text else 0

        Button:
            text: "Save Address"
            size_hint_y: None
            height: dp(55)
            font_size: 20
            bold: True
            color: (1, 1, 1, 1)
            background_normal: ''
            background_color: (0.1, 0.6, 0.9, 1)
            canvas.before:
                Color:
                    rgba: (0.1, 0.6, 0.9, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]
            on_press: app.save_new_address(address_input.text)

        Widget: